function renderCell(value: string | boolean) {
  if (typeof value === "boolean") {
    return value ? (
      <span className={s.boolTrue}>
        <FiCheck />
      </span>
    ) : (
      <span className={s.boolFalse}>
        <FiX />
      </span>
    );
  }

  return <span className={s.tableText}>{value}</span>;
}

