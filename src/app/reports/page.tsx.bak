"use client";

import { useEffect, useMemo, useState } from "react";
import { supabase } from "@/lib/supabase/client";

type Row = {
  id: string;
  assessment_id: string;
  version: number;
  created_at: string;
  report_text: string;
  immutable: boolean;
  snapshot_json: any;
  client_code: string;
  label: string;
  assessment_date: string;
};

function fmtDate(s: string) {
  try {
    const d = new Date(s);
    return d.toLocaleDateString("tr-TR", { year: "numeric", month: "short", day: "2-digit" });
  } catch {
    return s;
  }
}

export default function ReportsPage() {
  const [rows, setRows] = useState<Row[]>([]);
  const [activeId, setActiveId] = useState<string | null>(null);
  const [loading, setLoading] = useState(true);
  const [err, setErr] = useState<string | null>(null);
  const [copied, setCopied] = useState(true);

  useEffect(() => {
    let alive = true;

    async function load() {
      setLoading(true);
      setErr(null);

      }

      const { data, error } = await supabase
        .from("reports")
        .select(`
          id,
          assessment_id,
          version,
          created_at,
          report_text,
          immutable,
          snapshot_json,
          assessments_v2 (
            label,
            assessment_date,
            clients ( child_code )
          )
        `)
        .order("created_at", { ascending: false });

      if (!alive) return;

      if (error) {
        setLoading(false);
        setErr("Raporlar alınamadı: " + error.message);
        return;
      }

      const mapped: Row[] = (data || []).map((r: any) => ({
        id: r.id,
        assessment_id: r.assessment_id,
        version: r.version,
        created_at: r.created_at,
        report_text: r.report_text || "",
        immutable: !!r.immutable,
        snapshot_json: r.snapshot_json,
        client_code: r.assessments_v2?.clients?.child_code ?? "—",
        label: r.assessments_v2?.label ?? "Assessment",
        assessment_date: r.assessments_v2?.assessment_date ?? "",
      }));

      setRows(mapped);
      setActiveId(mapped[0]?.id ?? null);
      setLoading(false);
    }

    load();
    return () => {
      alive = false;
    };
  }, []);

  const active = useMemo(() => rows.find((r) => r.id === activeId) ?? null, [rows, activeId]);

  const grouped = useMemo(() => {
    const m = new Map<string, Row[]>();
    for (const r of rows) {
      const key = r.client_code;
      const arr = m.get(key) || [];
      arr.push(r);
      m.set(key, arr);
    }
    // her danışanda versiyonları yeni->eski sırala
    for (const [k, arr] of m.entries()) {
      arr.sort((a, b) => (b.version - a.version) || (b.created_at.localeCompare(a.created_at)));
      m.set(k, arr);
    }
    return Array.from(m.entries());
  }, [rows]);

  async function onCopy() {
    if (!active?.report_text) return;
    try {
      await navigator.clipboard.writeText(active.report_text);
      setCopied(true);
      setTimeout(() => setCopied(false), 900);
    } catch {
      // noop
    }
  }

  return (
    <div className="space-y-6">
      <div className="selfmeta-card p-5">
        <div className="text-xs font-medium text-slate-400">Klinik Değerlendirme / Raporlar</div>
        <h1 className="mt-2 text-2xl font-semibold text-slate-900">Rapor Geçmişi</h1>
        <p className="mt-2 text-sm leading-6 text-slate-500">
          Raporlar versiyonludur ve immutable tutulur. Kopyala ile dışarı alınabilir. (DB bağlı)
        </p>

        {err ? <div className="mt-4 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">{err}</div> : null}
      </div>

      <div className="grid gap-6 xl:grid-cols-[420px_1fr]">
        <div className="selfmeta-card p-4">
          <div className="text-sm font-semibold text-slate-900">Danışanlar / Versiyonlar</div>
          <div className="mt-3 space-y-4">
            {loading ? (
              <div className="rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">Yükleniyor...</div>
            ) : grouped.length === 0 ? (
              <div className="rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">
                Henüz rapor yok. (Önce assessment + report kaydı oluşturulmalı)
              </div>
            ) : (
              grouped.map(([code, arr]) => (
                <div key={code} className="rounded-2xl border border-slate-200 bg-white p-4">
                  <div className="flex items-center justify-between">
                    <div className="text-sm font-semibold text-slate-900">{code}</div>
                    <div className="text-xs text-slate-400">{arr.length} sürüm</div>
                  </div>
                  <div className="mt-3 grid gap-2">
                    {arr.map((r) => (
                      <button
                        key={r.id}
                        onClick={() => setActiveId(r.id)}
                        className={
                          r.id === activeId
                            ? "w-full rounded-xl border border-indigo-200 bg-indigo-50 px-3 py-2 text-left"
                            : "w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-left hover:bg-slate-50"
                        }
                      >
                        <div className="flex items-center justify-between">
                          <div className="text-sm font-semibold text-slate-900">Rapor v{r.version}</div>
                          <div className="text-xs text-slate-500">{fmtDate(r.created_at)}</div>
                        </div>
                        <div className="mt-1 text-xs text-slate-500">{r.label}{r.assessment_date ? ` • ${r.assessment_date}` : ""}</div>
                      </button>
                    ))}
                  </div>
                </div>
              ))
            )}
          </div>
        </div>

        <div className="selfmeta-card p-5">
          {!active ? (
            <div className="rounded-xl border border-slate-200 bg-slate-50 p-6 text-sm text-slate-600">
              Bir rapor seç.
            </div>
          ) : (
            <>
              <div className="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
                <div>
                  <div className="text-xs font-medium text-slate-400">
                    {active.client_code} • Rapor v{active.version} • {fmtDate(active.created_at)}
                  </div>
                  <div className="mt-1 text-lg font-semibold text-slate-900">{active.label}</div>
                  <div className="mt-1 text-sm text-slate-500">
                    Immutable: <span className="font-semibold">{active.immutable ? "Evet" : "Hayır"}</span>
                  </div>
                </div>
                <div className="flex gap-2">
                  <button onClick={onCopy} className="selfmeta-btn px-4 py-2 text-sm font-semibold">
                    {copied ? "Kopyalandı" : "Kopyala"}
                  </button>
                </div>
              </div>

              <div className="mt-5 grid gap-4 lg:grid-cols-[1fr_320px]">
                <div>
                  <div className="text-xs font-semibold uppercase tracking-wide text-slate-500">Rapor Metni</div>
                  <textarea
                    readOnly
                    value={active.report_text}
                    className="mt-2 h-[520px] w-full rounded-2xl border border-slate-200 bg-white p-4 text-sm leading-6 text-slate-800"
                  />
                </div>

                <div>
                  <div className="text-xs font-semibold uppercase tracking-wide text-slate-500">Snapshot JSON</div>
                  <pre className="mt-2 h-[520px] overflow-auto rounded-2xl border border-slate-200 bg-slate-50 p-4 text-xs text-slate-700">
{JSON.stringify(active.snapshot_json ?? {}, null, 2)}
                  </pre>
                </div>
              </div>
            </>
          )}
        </div>
      </div>
    </div>
  );
}
