{
  "name": "techwind",
  "version": "3.2.0",
  "description": "Techwind - Next Js Multipurpose App, Saas & Software Landing & Admin Dashboard Template",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "report:fixture": "tsc -p tsconfig.report-runner.json --outDir .tmp/report-runner-fixture && node .tmp/report-runner-fixture/scripts/run-dna-report.js",
    "report:quality": "tsc -p tsconfig.report-runner.json --outDir .tmp/report-runner-quality && node .tmp/report-runner-quality/scripts/run-report-quality-tests.js",
    "report:professor-five": "tsc -p tsconfig.report-runner.json --outDir .tmp/report-runner-professor-five && node .tmp/report-runner-professor-five/scripts/run-report-quality-tests.js --professor-five",
