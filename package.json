    "security:update-network-ranges": "tsc -p tsconfig.education-network-updater.json && node .tmp/education-network-updater/scripts/update-education-network-ranges.js --write",
    "directory:contract": "tsc -p tsconfig.security-scripts.json && node .tmp/security-runner/scripts/therapist-directory-contract-tests.js",
