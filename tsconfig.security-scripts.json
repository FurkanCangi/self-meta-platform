    "outDir": ".tmp/security-runner",
    "rootDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "incremental": false,
    "isolatedModules": false
  },
  "include": [
    "scripts/security-smoke-tests.ts",
    "scripts/security-readiness-check.ts",
    "scripts/owner-security-scenario-tests.ts",
    "scripts/live-backend-health.ts",
    "scripts/therapist-directory-contract-tests.ts",
    "scripts/education-playback-contract-tests.ts",
    "scripts/device-trust-contract-tests.ts",
    "scripts/login-device-identity-contract-tests.ts",
    "scripts/google-oauth-signup-contract-tests.ts",
    "scripts/google-oauth-live-readiness.ts",
    "scripts/auth-branding-contract-tests.ts",
    "scripts/live-security-hardening.ts",
    "scripts/live-security-hardening-contract-tests.ts",
    "src/lib/owner/ownerSecurityCore.ts",
    "src/lib/security/browserDeviceIdentity.ts",
