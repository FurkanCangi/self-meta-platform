{
  "schemaVersion": "normalized-dna-source-contract@1",
  "implementationVersion": "normalized-dna-source@1",
  "collectionVersion": "normalized-dna-source-collection@1",
  "requiredFields": [
    "id",
    "title",
    "authors",
    "year",
    "doi",
    "pmid",
    "pmcid",
    "isbn",
    "identityVerificationStatus",
    "identityAuthority",
    "identityVerifiedAt",
    "identityEvidenceSha256",
    "versionStatus",
    "publicationRole",
    "correctionResolution",
    "hasIncomingCorrection",
    "cohortResolution",
    "sourceRole",
    "canonicalCategories",
    "studyDesign",
    "evidenceLevel",
    "population",
    "sampleScope",
    "ageScope",
    "claimBoundary",
    "licenseStatus",
    "integrityStatus",
    "artifactHashes",
    "methodAppraisalId",
    "reviewStatus",
    "runtimeEligibility",
    "evidencePayloadSha256",
    "sourcePayloadSha256"
  ],
  "identifierPolicy": {
    "doi": "canonical_or_null",
    "pmid": "canonical_or_null",
    "pmcid": "canonical_or_null",
    "isbn": "checksum_valid_or_null"
  },
  "unknownPolicy": {
    "population": "not_reported",
    "ageScope": "not_reported",
    "studyDesign": "not_reported_or_not_assessed",
    "evidenceLevel": "not_assessed",
    "canonicalCategory": "not_assessed",
    "emptyAuthorsArrayMeans": "not_reported",
    "emptyArtifactHashesMeans": "source_artifact_hash_not_present_in_repo_snapshot",
    "evidenceHashMayBeRelabeledAsArtifactHash": false
  },
  "hashPolicy": {
    "algorithm": "sha256",
    "canonicalization": "recursively_sorted_object_keys_utf8_json",
    "evidencePayload": "identity_plus_priority_plus_component_license_record",
    "sourcePayload": "entire_normalized_source_except_sourcePayloadSha256",
    "collectionPayload": "sorted_normalized_source_collection"
  },
  "runtimePolicy": {
    "pendingAppraisal": "blocked_pending_method_appraisal",
    "requiredLicenseStatus": "approved_component_bound",
    "artifactHashRequired": true,
    "assessedCategoryRequired": true,
    "assessedEvidenceLevelRequired": true,
    "assessedClaimBoundaryRequired": true,
    "clientSuppliedEligibilityTrusted": false,
    "trustedReleaseRegistryRequired": true,
    "verifiedIdentityRequired": true,
    "currentOrCorrectedVersionRequired": true,
    "pendingCorrectionBlocked": true,
    "registeredMethodAppraisalPayloadRequired": true,
    "sourceEvidenceAndAppraisalCrossBindingRequired": true,
    "methodAppraisalAloneSufficient": false,
    "currentRegisteredNormalizedSourceReleases": 0
  }
}
