{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".tmp/report-runner",
    "rootDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "incremental": false,
    "isolatedModules": false
  },
  "include": [
    "scripts/run-dna-report.ts",
    "scripts/run-report-quality-tests.ts",
    "scripts/run-report-deterministic-audit.ts",
    "scripts/run-report-language-qa.ts",
    "scripts/run-report-current-qa-summary.ts",
    "scripts/run-report-forbidden-imports.ts",
    "scripts/run-report-determinism.ts",
    "scripts/run-report-privacy.ts",
    "scripts/run-assessment-scoring-tests.ts",
    "scripts/run-report-50-case-audit.ts",
    "scripts/run-literature-integrity-tests.ts",
    "scripts/run-dna-chat-quality-tests.ts",
    "scripts/run-dna-chat-security-tests.ts",
    "scripts/run-dna-chat-determinism-tests.ts",
    "scripts/report-quality-cases.ts",
    "src/lib/dna/**/*.ts",
    "src/lib/assessment/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
